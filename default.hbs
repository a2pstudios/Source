<!DOCTYPE html>
<html lang="{{@site.locale}}" data-theme="light">

<head>
    <link rel="preload" href="https://fonts.bunny.net/css?family=Manrope:400,500,600,700,800&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{meta_title page=(t " (Page %)")}}</title>
    <link rel="stylesheet" href="{{asset "built/screen.css"}}">
    <link rel="stylesheet" href="{{asset "css/custom.css"}}">
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-77SJ3C7RN2"></script>
    <script defer src="{{asset "js/custom.js"}}"></script>

    {{!-- Prevent dark mode flash: set theme before render --}}
    <script>
    (function() {
        var scheme = '{{@custom.color_scheme}}';
        var stored = null;
        try { stored = localStorage.getItem('fq-color-scheme'); } catch(e) {}
        var theme = 'light';
        if (scheme === 'Dark') {
            theme = 'dark';
        } else if (scheme === 'Light') {
            theme = 'light';
        } else if (stored === 'dark' || stored === 'light') {
            theme = stored;
        } else if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
            theme = 'dark';
        }
        document.documentElement.setAttribute('data-theme', theme);
    })();
    </script>

    {{ghost_head}}
</head>

<body class="{{body_class}}{{{block "body_class"}}} is-head-{{#match @custom.navigation_layout "Logo on the left"}}left-logo{{else match @custom.navigation_layout "Logo in the middle"}}middle-logo{{else}}stacked{{/match}}{{#match @custom.title_font "=" "Elegant serif"}} has-serif-title{{/match}}{{#match @custom.body_font "=" "Elegant serif"}} has-serif-body{{/match}}{{#is "tag"}}{{#if tag.feature_image}} is-head-transparent{{/if}}{{/is}}{{#match @custom.header_style "Accent color"}} is-head-brand{{/match}}{{#match @custom.header_style "Dark"}} is-head-dark{{/match}} is-feed-{{#match @custom.post_feed_layout "List"}}list{{else}}grid{{/match}} is-color-scheme-{{#match @custom.color_scheme "Dark"}}dark{{else match @custom.color_scheme "Light"}}light{{else}}system{{/match}}">
<!-- FQPEDIA_VER_1.2.0 -->

{{!-- TradingView Ticker Disabled --}}
{{!-- <div class="tradingview-widget-container" id="tv-ticker-wrapper">
    <div class="tradingview-widget-container__widget"></div>
</div> --}}

<div class="gh-site">

    <header id="gh-head" class="gh-head gh-outer">
        <div class="gh-head-inner gh-inner">
            <div class="gh-head-brand">
                <div class="gh-head-brand-wrapper">
                    {{#is "home"}}<h1 class="gh-head-logo">{{/is}}
                    <a {{^is "home"}}class="gh-head-logo"{{/is}} href="{{@site.url}}">
                        <img class="gh-head-logo-light" src="{{asset "images/FQpedia-logo-2026.svg"}}" alt="{{@site.title}}">
                        {{#if @custom.dark_mode_logo}}
                            <img class="gh-head-logo-dark" src="{{@custom.dark_mode_logo}}" alt="{{@site.title}}" style="display:none;">
                        {{/if}}
                    </a>
                    {{#is "home"}}</h1>{{/is}}
                </div>
                <button class="gh-search gh-icon-btn" aria-label="{{t "Search this site"}}" data-ghost-search>{{> "icons/search"}}</button>
                {{#match @custom.color_scheme "System"}}
                <button class="gh-theme-toggle gh-icon-btn" aria-label="Toggle dark mode" title="切換深色模式">
                    <svg class="gh-theme-toggle-sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
                    <svg class="gh-theme-toggle-moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
                </button>
                {{/match}}
                <button class="gh-burger" aria-label="{{t "Toggle menu"}}"></button>
            </div>

            <nav class="gh-head-menu">
                {{> "navigation"}}
                {{#unless @site.members_enabled}}
                    {{#match @custom.navigation_layout "Stacked"}}
                        <button class="gh-search gh-icon-btn" aria-label="{{t "Search this site"}}" data-ghost-search>{{> "icons/search"}}</button>
                    {{/match}}
                {{/unless}}
            </nav>

            <div class="gh-head-actions">
                {{#unless @site.members_enabled}}
                    {{^match @custom.navigation_layout "Stacked"}}
                        <button class="gh-search gh-icon-btn" aria-label="{{t "Search this site"}}" data-ghost-search>{{> "icons/search"}}</button>
                    {{/match}}
                    {{#match @custom.color_scheme "System"}}
                    <button class="gh-theme-toggle gh-icon-btn" aria-label="Toggle dark mode" title="切換深色模式">
                        <svg class="gh-theme-toggle-sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
                        <svg class="gh-theme-toggle-moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
                    </button>
                    {{/match}}
                {{else}}
                    <button class="gh-search gh-icon-btn" aria-label="{{t "Search this site"}}" data-ghost-search>{{> "icons/search"}}</button>
                    {{#match @custom.color_scheme "System"}}
                    <button class="gh-theme-toggle gh-icon-btn" aria-label="Toggle dark mode" title="切換深色模式">
                        <svg class="gh-theme-toggle-sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
                        <svg class="gh-theme-toggle-moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
                    </button>
                    {{/match}}
                    <div class="gh-head-members">
                        {{#unless @member}}
                            {{#unless @site.members_invite_only}}
                                <a class="gh-head-link" href="#/portal/signin" data-portal="signin">{{t "Sign in"}}</a>
                                <a class="gh-head-btn gh-btn gh-primary-btn" href="#/portal/signup" data-portal="signup">{{t "Subscribe"}}</a>
                            {{else}}
                                <a class="gh-head-btn gh-btn gh-primary-btn" href="#/portal/signin" data-portal="signin">{{t "Sign in"}}</a>
                            {{/unless}}
                        {{else}}
                            <a class="gh-head-btn gh-btn gh-primary-btn" href="#/portal/account" data-portal="account">{{t "Account"}}</a>
                        {{/unless}}
                    </div>
                {{/unless}}
            </div>
        </div>
    </header>

    {{{body}}}

    <footer class="gh-foot gh-outer">
        <div class="gh-foot-inner gh-inner">
            {{#if @site.members_enabled}}
            {{#unless @member}}
                <section class="gh-subscribe">
                    <h3 class="gh-subscribe-title">{{t "Subscribe to {sitetitle}" sitetitle=@site.title}}</h3>
                    {{#if @custom.email_signup_text}}
                        <div class="gh-subscribe-description">{{@custom.email_signup_text}}</div>
                    {{/if}}
                    <button class="gh-subscribe-btn gh-btn" data-portal="signup">{{> "icons/email"}} {{t "Subscribe now"}}</button>
                </section>
            {{/unless}}
            {{/if}}

            <div class="site-footer-container">
                <div class="footer-social-links">
                    {{#if @site.facebook}}
                        <a href="{{facebook_url @site.facebook}}" target="_blank" rel="noopener" aria-label="Facebook">{{> "icons/facebook"}}</a>
                    {{/if}}
                    {{#if @site.twitter}}
                        <a href="{{twitter_url @site.twitter}}" target="_blank" rel="noopener" aria-label="Twitter">{{> "icons/twitter"}}</a>
                    {{/if}}
                    {{#if @custom.social_instagram_url}}
                        <a href="{{@custom.social_instagram_url}}" target="_blank" rel="noopener" aria-label="Instagram">{{> "icons/instagram"}}</a>
                    {{/if}}
                    {{#if @custom.social_youtube_url}}
                        <a href="{{@custom.social_youtube_url}}" target="_blank" rel="noopener" aria-label="Youtube">{{> "icons/youtube"}}</a>
                    {{/if}}
                    {{#if @custom.social_tiktok_url}}
                        <a href="{{@custom.social_tiktok_url}}" target="_blank" rel="noopener" aria-label="TikTok">{{> "icons/tiktok"}}</a>
                    {{/if}}
                    {{#if @custom.social_linkedin_url}}
                        <a href="{{@custom.social_linkedin_url}}" target="_blank" rel="noopener" aria-label="LinkedIn">{{> "icons/linkedin"}}</a>
                    {{/if}}
                    {{#if @custom.social_bluesky_url}}
                        <a href="{{@custom.social_bluesky_url}}" target="_blank" rel="noopener" aria-label="Bluesky">{{> "icons/bluesky"}}</a>
                    {{/if}}
                    {{#if @custom.social_threads_url}}
                        <a href="{{@custom.social_threads_url}}" target="_blank" rel="noopener" aria-label="Threads">{{> "icons/threads"}}</a>
                    {{/if}}
                </div>

                {{!-- Secondary navigation with grouped column support --}}
                <nav class="footer-secondary-nav" id="gh-footer-nav">
                {{#foreach @site.secondary_navigation}}
                    <span class="footer-nav-item" data-nav-label="{{label}}" data-nav-url="{{url}}">
                        <a href="{{url}}">{{label}}</a>
                    </span>
                {{/foreach}}
                </nav>

                {{!-- Fallback: show hardcoded links if no secondary navigation is configured --}}
                {{#unless @site.secondary_navigation}}
                <nav class="footer-legal-links">
                    <a href="https://fqpedia.com/about/">關於FQpedia</a>
                    <a href="https://fqpedia.com/#/portal/">註冊會員</a>
                    <a href="/terms/">使用條款</a>
                    <a href="/privacy/">私隱政策</a>
                    <a href="/contact/">聯絡我們</a>
                </nav>
                {{/unless}}

                <div class="footer-disclaimer">
                    <p class="disclaimer-text">
                        免責聲明：本網頁刊載的所有投資技巧及分析，僅供參考用途。讀者作出任何投資決定前，要自行判斷及審慎處理，更要自行掌握最新的市場資訊。本網站及其內容提供者不就任何內容的準確性、完整性或適用性作出任何明示或默示的保證。在任何情況下，本網站及其內容提供者均不對因使用或依賴本網站上的任何內容而直接或間接造成的任何損失或損害承擔責任。
                    </p>
                </div>

                <div class="footer-copyright">
                    © 2025-2026 FQpedia. All rights reserved.
                </div>
            </div>
        </div>
    </footer>

</div>

{{#is "post, page"}}
    {{> "pswp"}}
{{/is}}

<script src="{{asset "built/main.min.js"}}"></script>

{{ghost_foot}}

</body>

</html>
