<article class="gh-card gh-card-list {{post_class}}">
    <a class="gh-card-link" href="{{url}}">
        {{#if feature_image}}
            <figure class="gh-card-image">
                <img
                    srcset="{{img_url feature_image size="xs"}} 150w,
                            {{img_url feature_image size="s"}} 300w,
                            {{img_url feature_image size="m"}} 720w"
                    sizes="(max-width: 767px) 100px, 200px"
                    src="{{img_url feature_image size="s"}}"
                    alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                    loading="lazy"
                >
            </figure>
        {{/if}}
        <div class="gh-card-wrapper">
            <header class="gh-card-header">
                <h3 class="gh-card-title">{{title}}</h3>
            </header>
            {{#if excerpt}}
                <div class="gh-card-excerpt">{{excerpt words="40"}}</div>
            {{/if}}
            <footer class="gh-card-footer">
                <span class="gh-card-author">{{#foreach authors}}{{#if @first}}{{name}}{{else}}, {{name}}{{/if}}{{/foreach}}</span>
                <time class="gh-card-date" datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD MMM YYYY"}}</time>
                {{#if @site.comments_enabled}}
                    {{comment_count class="gh-card-comments"}}
                {{/if}}
            </footer>
        </div>
    </a>
</article>
