{{!< default}}

<main class="gh-main gh-outer">
    <div class="gh-inner">

        {{!-- 1. Hero Grid Section --}}
        <section class="fq-hero-grid">
            {{#get "posts" include="authors,tags" limit="4" as |hero_posts|}}
                {{#foreach hero_posts}}
                    {{#if @first}}
                        {{!-- Left Side: Large Main Post --}}
                        <div class="fq-main-post">
                            <article class="fq-hero-post-large">
                                <a class="fq-hero-post-link" href="{{url}}">
                                    {{#if feature_image}}
                                        <img class="fq-hero-post-image" src="{{img_url feature_image size="xl"}}" alt="{{title}}">
                                    {{/if}}
                                    <div class="fq-hero-post-content">
                                        <div class="fq-hero-post-tags">
                                            {{#if primary_tag}}
                                                <span class="fq-tag">{{primary_tag.name}}</span>
                                            {{/if}}
                                        </div>
                                        <h2 class="fq-hero-post-title">{{title}}</h2>
                                        <div class="fq-hero-post-meta">
                                            <span class="fq-author">BY {{authors}}</span>
                                            <time class="fq-date" datetime="{{date format="YYYY-MM-DD"}}">{{date format="MMM DD, YYYY"}}</time>
                                        </div>
                                    </div>
                                </a>
                            </article>
                        </div>
                        <div class="fq-sidebar-posts">
                    {{else}}
                        {{!-- Right Side: 3 Vertical Small Posts --}}
                        <article class="fq-hero-post-small">
                            <a class="fq-hero-post-small-link" href="{{url}}">
                                {{#if feature_image}}
                                    <div class="fq-hero-post-small-image-wrapper">
                                        <img src="{{img_url feature_image size="s"}}" alt="{{title}}">
                                    </div>
                                {{/if}}
                                <div class="fq-hero-post-small-content">
                                    <h3 class="fq-hero-post-small-title">{{title}}</h3>
                                    <div class="fq-hero-post-meta">
                                        <span class="fq-author">BY {{authors}}</span>
                                        <time class="fq-date" datetime="{{date format="YYYY-MM-DD"}}">{{date format="MMM DD, YYYY"}}</time>
                                    </div>
                                </div>
                            </a>
                        </article>
                    {{/if}}
                    {{#if @last}}
                        </div>
                    {{/if}}
                {{/foreach}}
            {{/get}}
        </section>

        {{!-- 2. Collection Sections --}}
        {{#get "tags" limit="4" include="count.posts" order="count.posts desc"}}
            {{#foreach tags}}
                <section class="fq-collection">
                    <header class="fq-collection-header">
                        <h2 class="fq-collection-title">{{name}}</h2>
                        <a href="{{url}}" class="fq-collection-view-all">View all &rarr;</a>
                    </header>
                    <div class="fq-collection-grid">
                        {{#get "posts" filter="tag:{{slug}}" limit="4" include="authors,tags"}}
                            {{#foreach posts}}
                                <article class="fq-grid-post">
                                    <a class="fq-grid-post-link" href="{{url}}">
                                        {{#if feature_image}}
                                            <div class="fq-grid-post-image-wrapper">
                                                <img src="{{img_url feature_image size="m"}}" alt="{{title}}">
                                            </div>
                                        {{/if}}
                                        <div class="fq-grid-post-content">
                                            <span class="fq-grid-post-tag">{{primary_tag.name}}</span>
                                            <h3 class="fq-grid-post-title">{{title}}</h3>
                                            <div class="fq-grid-post-meta">
                                                <span class="fq-author">BY {{authors}}</span>
                                                <time class="fq-date" datetime="{{date format="YYYY-MM-DD"}}">{{date format="MMM DD, YYYY"}}</time>
                                            </div>
                                        </div>
                                    </a>
                                </article>
                            {{/foreach}}
                        {{/get}}
                    </div>
                </section>
            {{/foreach}}
        {{/get}}

    </div>
</main>
