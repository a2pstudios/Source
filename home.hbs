{{!< default}}

<main class="gh-main gh-outer">
    <div class="gh-inner">

        {{!-- ========================================
             EDITORIAL FEATURED HERO (3-column)
             Left: 2 posts with thumbnails | Center: large hero | Right: 5 text-only
             ======================================== --}}
        {{#match @custom.hero_layout "Email Subscription"}}
            <section class="fq-subscribe-cta" style="margin-top: 32px;">
                {{#if @custom.hero_headline}}<h3>{{@custom.hero_headline}}</h3>{{/if}}
                {{#if @custom.hero_subheadline}}<p>{{@custom.hero_subheadline}}</p>{{/if}}
                <button class="fq-subscribe-btn" data-portal="signup">{{t "Subscribe now"}}</button>
            </section>

        {{else match @custom.hero_layout "Call to Action"}}
            <section class="fq-subscribe-cta" style="margin-top: 32px;">
                {{#if @custom.hero_headline}}<h3>{{@custom.hero_headline}}</h3>{{/if}}
                {{#if @custom.hero_subheadline}}<p>{{@custom.hero_subheadline}}</p>{{/if}}
                <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
                    <button class="fq-subscribe-btn" data-portal="signup">{{t "Subscribe"}}</button>
                    {{#if @custom.hero_secondary_button_text}}
                        <a class="fq-subscribe-btn" style="background:var(--fq-text);" href="{{#if @custom.hero_secondary_button_link}}{{@custom.hero_secondary_button_link}}{{else}}{{@site.url}}{{/if}}">
                            {{@custom.hero_secondary_button_text}}
                        </a>
                    {{/if}}
                </div>
            </section>

        {{else match @custom.hero_layout "Personal Bio"}}
            {{#if @custom.hero_author_slug}}
                {{#get "authors" filter="slug:{{@custom.hero_author_slug}}" limit="1" as |bio_authors|}}
                    {{#foreach bio_authors}}
                        <section class="fq-subscribe-cta" style="margin-top:32px;display:flex;align-items:center;gap:24px;text-align:left;">
                            {{#if profile_image}}
                                <img src="{{profile_image}}" alt="{{name}}" style="width:80px;height:80px;border-radius:50%;object-fit:cover;flex-shrink:0;">
                            {{/if}}
                            <div>
                                <h3>{{name}}</h3>
                                {{#if bio}}<p>{{bio}}</p>{{/if}}
                                <a href="{{url}}" style="color:var(--fq-accent);font-weight:600;font-size:14px;">{{t "View all posts"}} &rarr;</a>
                            </div>
                        </section>
                    {{/foreach}}
                {{/get}}
            {{/if}}

        {{else}}
            {{!-- Featured Posts (default) - Editorial 3-column --}}
            {{#get "posts" include="authors,tags" limit="8" as |hero_posts|}}
                <section class="fq-editorial">
                    {{!-- Center: Large hero (first post) --}}
                    <div class="fq-editorial-center">
                        {{#foreach hero_posts limit="1"}}
                            <a class="fq-hero-card" href="{{url}}">
                                {{#if feature_image}}
                                    <div class="fq-card-image">
                                        <img src="{{img_url feature_image size="xl"}}" alt="{{title}}" fetchpriority="high" loading="eager">
                                    </div>
                                {{/if}}
                                <div class="fq-card-content">
                                    {{#if primary_tag}}
                                        <div class="fq-tags">
                                            <span class="fq-tag">{{primary_tag.name}}</span>
                                        </div>
                                    {{/if}}
                                    <h2 class="fq-heading-xl"><a href="{{url}}">{{title}}</a></h2>
                                    <div class="fq-byline">
                                        <span>{{#foreach authors}}{{#if @first}}{{name}}{{/if}}{{/foreach}}</span>
                                        <span>&middot;</span>
                                        <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="MMM DD, YYYY"}}</time>
                                    </div>
                                </div>
                            </a>
                        {{/foreach}}
                    </div>

                    {{!-- Left: 2 posts with thumbnails (posts 2-3) --}}
                    <div class="fq-editorial-left">
                        {{#foreach hero_posts from="2" limit="2"}}
                            <a class="fq-side-card" href="{{url}}">
                                {{#if feature_image}}
                                    <div class="fq-card-image">
                                        <img src="{{img_url feature_image size="s"}}" alt="{{title}}" loading="lazy">
                                    </div>
                                {{/if}}
                                <div class="fq-card-content">
                                    {{#if primary_tag}}
                                        <div class="fq-tags"><span class="fq-tag">{{primary_tag.name}}</span></div>
                                    {{/if}}
                                    <h3 class="fq-heading-md"><a href="{{url}}">{{title}}</a></h3>
                                    <div class="fq-byline">
                                        <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="MMM DD, YYYY"}}</time>
                                    </div>
                                </div>
                            </a>
                        {{/foreach}}
                    </div>

                    {{!-- Right: 5 text-only posts (posts 4-8) --}}
                    <div class="fq-editorial-right">
                        {{#foreach hero_posts from="4" limit="5"}}
                            <a class="fq-text-card" href="{{url}}">
                                <div class="fq-card-content">
                                    {{#if primary_tag}}
                                        <div class="fq-tags"><span class="fq-tag">{{primary_tag.name}}</span></div>
                                    {{/if}}
                                    <h3 class="fq-heading-sm"><a href="{{url}}">{{title}}</a></h3>
                                    <div class="fq-byline">
                                        <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="MMM DD, YYYY"}}</time>
                                    </div>
                                </div>
                            </a>
                        {{/foreach}}
                    </div>
                </section>
            {{/get}}
        {{/match}}

        {{!-- ========================================
             LATEST SECTION + Feed Tabs
             ======================================== --}}
        <section class="fq-section" style="border-bottom: 1px solid var(--fq-border);">
            <div class="fq-latest-header">
                <h2 class="fq-latest-title">
                    {{#match pagination.pages ">" 1}}
                        <a href="{{@site.url}}/page/2">{{t "Latest"}}</a>
                    {{else}}
                        {{t "Latest"}}
                    {{/match}}
                </h2>
                {{#if @custom.enter_tag_slugs_for_primary_sections}}
                    <nav class="fq-feed-tabs">
                        <a href="{{@site.url}}" class="fq-feed-tab is-active">{{t "Latest"}}</a>
                        {{#get "tags" filter="slug:[{{@custom.enter_tag_slugs_for_primary_sections}}]" limit="10" as |feed_tags|}}
                            {{#foreach feed_tags}}
                                <a href="{{url}}" class="fq-feed-tab">{{name}}</a>
                            {{/foreach}}
                        {{/get}}
                    </nav>
                {{/if}}
            </div>

            <div class="fq-post-grid">
                {{#foreach posts limit="8"}}
                    <a class="fq-grid-card" href="{{url}}">
                        {{#if feature_image}}
                            <div class="fq-card-image">
                                <img srcset="{{img_url feature_image size="s"}} 300w,
                                        {{img_url feature_image size="m"}} 720w,
                                        {{img_url feature_image size="l"}} 960w"
                                        sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 300px"
                                        src="{{img_url feature_image size="s"}}"
                                        alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                                        loading="lazy">
                            </div>
                        {{/if}}
                        <div class="fq-card-content">
                            {{#if primary_tag}}
                                <div class="fq-tags"><span class="fq-tag">{{primary_tag.name}}</span></div>
                            {{/if}}
                            <h3 class="fq-heading-md"><a href="{{url}}">{{title}}</a></h3>
                            <div class="fq-byline">
                                <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="MMM DD, YYYY"}}</time>
                            </div>
                        </div>
                    </a>
                {{/foreach}}
            </div>

            {{#match pagination.pages ">" 1}}
                <div style="text-align:center;padding-top:24px;">
                    <a href="{{@site.url}}/page/2" class="fq-view-all">
                        {{t "Show more"}}
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M2.25803e-06 7.28862L1.75227e-06 5.76562L10.4434 5.76562L5.76564 1.08784L6.8535 -1.70189e-05L13.3806 6.52712L6.8535 13.0543L5.76564 11.9664L10.4434 7.28862H2.25803e-06Z" fill="currentColor"/>
                        </svg>
                    </a>
                </div>
            {{/match}}
        </section>

        {{!-- ========================================
             TAG-BASED SECTIONS (Publisher-style)
             Each section: header (tag name + View all) + 4-column grid
             ======================================== --}}
        {{#if @custom.enter_tag_slugs_for_primary_sections}}
            {{#get "tags" filter="slug:[{{@custom.enter_tag_slugs_for_primary_sections}}]"}}
                {{#foreach tags}}
                    <section class="fq-section">
                        <div class="fq-section-header">
                            <h2 class="fq-section-title"><a href="{{url}}">{{name}}</a></h2>
                            <a href="{{url}}" class="fq-view-all">
                                View all
                                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M2.25803e-06 7.28862L1.75227e-06 5.76562L10.4434 5.76562L5.76564 1.08784L6.8535 -1.70189e-05L13.3806 6.52712L6.8535 13.0543L5.76564 11.9664L10.4434 7.28862H2.25803e-06Z" fill="currentColor"/>
                                </svg>
                            </a>
                        </div>
                        <div class="fq-post-grid">
                            {{#get "posts" include="tags,authors" filter="tag:{{slug}}" limit="4"}}
                                {{#foreach posts}}
                                    <a class="fq-grid-card" href="{{url}}">
                                        {{#if feature_image}}
                                            <div class="fq-card-image">
                                                <img srcset="{{img_url feature_image size="s"}} 300w,
                                                        {{img_url feature_image size="m"}} 720w"
                                                        sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 300px"
                                                        src="{{img_url feature_image size="s"}}"
                                                        alt="{{title}}"
                                                        loading="lazy">
                                            </div>
                                        {{/if}}
                                        <div class="fq-card-content">
                                            {{#if primary_tag}}
                                                <div class="fq-tags"><span class="fq-tag">{{primary_tag.name}}</span></div>
                                            {{/if}}
                                            <h3 class="fq-heading-md"><a href="{{url}}">{{title}}</a></h3>
                                            <div class="fq-byline">
                                                <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="MMM DD, YYYY"}}</time>
                                            </div>
                                        </div>
                                    </a>
                                {{/foreach}}
                            {{/get}}
                        </div>
                    </section>
                {{/foreach}}
            {{/get}}
        {{else}}
            {{#match posts.length ">" 1}}
                {{#get "tags" include="count.posts" order="count.posts desc" limit="3"}}
                    {{#foreach tags}}
                        <section class="fq-section">
                            <div class="fq-section-header">
                                <h2 class="fq-section-title"><a href="{{url}}">{{name}}</a></h2>
                                <a href="{{url}}" class="fq-view-all">
                                    View all
                                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M2.25803e-06 7.28862L1.75227e-06 5.76562L10.4434 5.76562L5.76564 1.08784L6.8535 -1.70189e-05L13.3806 6.52712L6.8535 13.0543L5.76564 11.9664L10.4434 7.28862H2.25803e-06Z" fill="currentColor"/>
                                    </svg>
                                </a>
                            </div>
                            <div class="fq-post-grid">
                                {{#get "posts" include="tags,authors" filter="tag:{{slug}}" limit="4"}}
                                    {{#foreach posts}}
                                        <a class="fq-grid-card" href="{{url}}">
                                            {{#if feature_image}}
                                                <div class="fq-card-image">
                                                    <img src="{{img_url feature_image size="s"}}" alt="{{title}}" loading="lazy">
                                                </div>
                                            {{/if}}
                                            <div class="fq-card-content">
                                                {{#if primary_tag}}
                                                    <div class="fq-tags"><span class="fq-tag">{{primary_tag.name}}</span></div>
                                                {{/if}}
                                                <h3 class="fq-heading-md"><a href="{{url}}">{{title}}</a></h3>
                                                <div class="fq-byline">
                                                    <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="MMM DD, YYYY"}}</time>
                                                </div>
                                            </div>
                                        </a>
                                    {{/foreach}}
                                {{/get}}
                            </div>
                        </section>
                    {{/foreach}}
                {{/get}}
            {{/match}}
        {{/if}}

        {{!-- Secondary sections (minimal list) --}}
        {{#if @custom.enter_tag_slugs_for_secondary_sections}}
            {{#get "tags" filter="slug:[{{@custom.enter_tag_slugs_for_secondary_sections}}]"}}
                {{#if tags}}
                    <section class="fq-section" style="border-bottom: none;">
                        <div class="fq-section-header">
                            <h2 class="fq-section-title">{{t "More"}}</h2>
                        </div>
                        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:24px;">
                            {{#foreach tags}}
                                <div>
                                    <h3 style="font-size:18px;font-weight:700;margin:0 0 12px;">
                                        <a href="{{url}}" style="text-decoration:none;color:var(--fq-text);">{{name}}</a>
                                    </h3>
                                    {{#get "posts" include="tags,authors" filter="tag:{{slug}}" limit="4"}}
                                        {{#foreach posts}}
                                            <a href="{{url}}" style="display:block;padding:10px 0;border-bottom:1px solid var(--fq-border-card);text-decoration:none;color:var(--fq-text);font-size:14px;font-weight:600;transition:color 0.3s ease;" onmouseover="this.style.color='var(--fq-accent)'" onmouseout="this.style.color='var(--fq-text)'">{{title}}</a>
                                        {{/foreach}}
                                    {{/get}}
                                </div>
                            {{/foreach}}
                        </div>
                    </section>
                {{/if}}
            {{/get}}
        {{/if}}

    </div>
</main>
