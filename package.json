{
    "name": "fqpedia-headline",
    "description": "A Ghost theme",
    "version": "1.3.2",
    "private": true,
    "engines": {
        "ghost": ">=5.0.0"
    },
    "license": "MIT",
    "author": {
        "name": "Ghost Foundation",
        "email": "hello@ghost.org",
        "url": "https://ghost.org"
    },
    "keywords": [
        "ghost",
        "theme",
        "ghost-theme"
    ],
    "docs": "https://headline.ghost.io/about/",
    "config": {
        "posts_per_page": 7,
        "image_sizes": {
            "xs": { "width": 150 },
            "s": { "width": 300 },
            "m": { "width": 720 },
            "l": { "width": 960 },
            "xl": { "width": 1200 },
            "xxl": { "width": 2000 }
        },
        "card_assets": true,
        "custom": {
            "navigation_layout": {
                "type": "select",
                "options": ["Logo on the left", "Logo in the middle", "Stacked"],
                "default": "Stacked"
            },
            "header_style": {
                "type": "select",
                "options": ["Light", "Accent color", "Dark"],
                "default": "Light"
            },
            "title_font": {
                "type": "select",
                "options": ["Modern sans-serif", "Elegant serif"],
                "default": "Modern sans-serif"
            },
            "body_font": {
                "type": "select",
                "options": ["Modern sans-serif", "Elegant serif"],
                "default": "Elegant serif"
            },
            "email_signup_text": {
                "type": "text",
                "default": "Don't miss out on the latest news. Sign up now to get access to the library of members-only articles."
            },
            "color_scheme": {
                "type": "select",
                "options": ["System", "Light", "Dark"],
                "default": "System",
                "description": "System follows the visitor's device setting and shows a toggle button"
            },
            "dark_mode_logo": {
                "type": "image",
                "description": "Optional alternate logo shown when dark mode is active"
            },
            "post_feed_layout": {
                "type": "select",
                "options": ["Grid", "List"],
                "default": "Grid"
            },
            "social_instagram_url": {
                "type": "text",
                "description": "Instagram profile URL, shown as an icon in the footer"
            },
            "social_youtube_url": {
                "type": "text",
                "description": "YouTube channel URL, shown as an icon in the footer"
            },
            "social_tiktok_url": {
                "type": "text",
                "description": "TikTok profile URL, shown as an icon in the footer"
            },
            "social_linkedin_url": {
                "type": "text",
                "description": "LinkedIn profile URL, shown as an icon in the footer"
            },
            "hero_layout": {
                "type": "select",
                "options": ["Featured Posts", "Email Subscription", "Call to Action", "Personal Bio"],
                "default": "Featured Posts",
                "group": "homepage",
                "description": "Choose what appears at the top of the homepage"
            },
            "hero_headline": {
                "type": "text",
                "group": "homepage",
                "description": "Used with Email Subscription / Call to Action / Personal Bio hero layouts"
            },
            "hero_subheadline": {
                "type": "text",
                "group": "homepage"
            },
            "hero_secondary_button_text": {
                "type": "text",
                "group": "homepage",
                "description": "Call to Action layout only - leave blank to show only the primary button"
            },
            "hero_secondary_button_link": {
                "type": "text",
                "group": "homepage"
            },
            "hero_author_slug": {
                "type": "text",
                "group": "homepage",
                "description": "Personal Bio layout only - the exact author slug to feature"
            },
            "enter_tag_slugs_for_primary_sections": {
                "type": "text",
                "group": "homepage",
                "description": "Comma-separated tag slugs - used for homepage feed tabs and featured tag sections"
            },
            "enter_tag_slugs_for_secondary_sections": {
                "type": "text",
                "group": "homepage"
            }
        }
    },
    "scripts": {
        "dev": "gulp",
        "test": "gscan .",
        "zip": "gulp zip"
    },
    "devDependencies": {
        "@tryghost/shared-theme-assets": "2.6.1",
        "@tryghost/theme-translations": "^0.0.9",
        "autoprefixer": "10.5.0",
        "beeper": "2.1.0",
        "cssnano": "7.1.7",
        "gscan": "5.4.3",
        "gulp": "5.0.1",
        "gulp-concat": "2.6.1",
        "gulp-livereload": "4.0.2",
        "gulp-postcss": "10.0.0",
        "gulp-uglify": "3.0.2",
        "gulp-zip": "5.1.0",
        "ordered-read-streams": "2.0.0",
        "postcss": "8.5.10",
        "postcss-easy-import": "4.0.0",
        "pump": "3.0.4"
    }
}
